{
  "autoUpdatesChannel": "latest",
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "model": "sonnet",
  "effortLevel": "medium",
  "defaultPermissionMode": "plan",
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": ["@playwright/mcp@latest"]
    }
  }
}
